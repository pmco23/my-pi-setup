{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pi Workflow Handoff",
  "type": "object",
  "required": ["workflow_mode", "current_skill", "next_skill", "requires_user", "stop_reason", "confidence", "reason", "inputs"],
  "properties": {
    "workflow_mode": { "type": "string", "enum": ["auto", "user-in-the-loop"] },
    "current_skill": { "type": "string", "minLength": 1 },
    "next_skill": { "type": "string", "minLength": 1 },
    "requires_user": { "type": "boolean" },
    "stop_reason": { "type": ["string", "null"] },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "reason": { "type": "string" },
    "inputs": {
      "type": "object",
      "required": ["primary_artifact", "required_context", "open_questions"],
      "properties": {
        "primary_artifact": { "type": "string" },
        "required_context": { "type": "array", "items": { "type": "string" } },
        "open_questions": { "type": "array", "items": { "type": "string" } },
        "project_config": { "type": "string" },
        "artifact_log": { "type": "string" }
      },
      "additionalProperties": true
    },
    "signals": {
      "type": "object",
      "properties": {
        "failed_validation": { "type": "boolean" },
        "blockers": { "type": "boolean" },
        "destructive_or_risky": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
