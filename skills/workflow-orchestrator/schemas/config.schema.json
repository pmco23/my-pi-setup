{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pi Workflow Orchestrator Config",
  "type": "object",
  "required": ["version", "default_mode", "default_sequence", "auto_continue", "handoff", "transitions", "active_workflow"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "default_mode": { "type": "string", "enum": ["auto", "user-in-the-loop"] },
    "default_sequence": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "auto_continue": {
      "type": "object",
      "required": ["enabled", "allowed_skills", "stop_on_open_questions", "stop_on_low_confidence", "stop_on_failed_validation", "stop_on_blockers", "stop_before_execute"],
      "properties": {
        "enabled": { "type": "boolean" },
        "allowed_skills": { "type": "array", "items": { "type": "string" } },
        "stop_on_open_questions": { "type": "boolean" },
        "stop_on_low_confidence": { "type": "boolean" },
        "stop_on_failed_validation": { "type": "boolean" },
        "stop_on_blockers": { "type": "boolean" },
        "stop_before_execute": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "handoff": {
      "type": "object",
      "required": ["require_json", "require_user_prompt", "persist_artifacts"],
      "properties": {
        "require_json": { "type": "boolean" },
        "require_user_prompt": { "type": "boolean" },
        "persist_artifacts": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "transitions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "support_skills": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["use_when", "allowed_in"],
        "properties": {
          "use_when": { "type": "string" },
          "allowed_in": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "active_workflow": {
      "type": "object",
      "required": ["id", "mode", "current_skill", "next_skill", "artifact_log", "updated_at"],
      "properties": {
        "id": { "type": ["string", "null"] },
        "mode": { "type": ["string", "null"], "enum": ["auto", "user-in-the-loop", null] },
        "current_skill": { "type": ["string", "null"] },
        "next_skill": { "type": ["string", "null"] },
        "artifact_log": { "type": ["string", "null"] },
        "updated_at": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
